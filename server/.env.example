# ── Morocco With You — Server Environment ──────────────────────
# Copy this file to server/.env and fill in your values.
# NEVER commit server/.env to version control.

PORT=3001
NODE_ENV=development

# API rate limiting applies when NODE_ENV=production. Dev skips limits (avoids 429 on localhost).
# Optional: API_RATE_LIMIT_MAX=500  RATE_LIMIT_DISABLED=1 (emergency: disable limit in prod)

# Supabase — find these in: Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # secret — server only
SUPABASE_ANON_KEY=your_anon_public_key_here

# ── Paid: OpenAI (optional) ───────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# If OpenAI hits 429 but you use Gemini: set SKIP_OPENAI=1 so auto picks Gemini for embed + chat.
# Or remove OPENAI_API_KEY / set AI_EMBEDDING_PROVIDER=gemini AI_CHAT_PROVIDER=gemini
SKIP_OPENAI=

# ── Free cloud: Google Gemini (recommended for production demos) ─
# Create key: https://aistudio.google.com/apikey — paste below (no card on free tier).
# Same key works on Render/Railway/Fly. Embeddings = 768 dims → run schema_pgvector_ollama_768.sql
GEMINI_API_KEY=
# Alternative env name (either works):
GOOGLE_AI_API_KEY=
# Use embedContent-supported id (NOT text-embedding-004 — that 404s on this API).
GEMINI_EMBED_MODEL=gemini-embedding-001
# Must match Supabase vector column size (768 = schema_pgvector_ollama_768.sql).
GEMINI_EMBED_OUTPUT_DIM=768
# Use a current stable id (2.0 Flash is deprecated on the Gemini API — avoid gemini-2.0-flash).
GEMINI_CHAT_MODEL=gemini-2.5-flash
# If rate-limited, increase ms between embed calls (default 100 for Gemini).
GEMINI_EMBED_DELAY_MS=100

# ── Free local: Ollama (https://ollama.com) — dev machine only ─
# Install Ollama, then: ollama pull nomic-embed-text && ollama pull llama3.2
# If OPENAI_API_KEY is empty: auto uses Gemini key if set, else Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
# Optional delay between embed API calls (ms). 0 = fast for local Ollama.
OLLAMA_EMBED_DELAY_MS=0

# openai | gemini | ollama | auto
AI_EMBEDDING_PROVIDER=auto
AI_CHAT_PROVIDER=auto

# Chat guardrail: extra LLM call to classify scope/safety. Set 0|false|off to disable.
GUARDRAIL_ENABLED=1
# Versioned prompts + guardrail templates: run server/schema_prompt_templates.sql in Supabase.

# Supabase vector size: OpenAI = 1536. Gemini (gemini-embedding-001 @ 768) & Ollama nomic = 768.
# For Gemini/Ollama embeddings run server/schema_pgvector_ollama_768.sql once
# (truncate catalogue_embeddings if you previously used 1536-dim OpenAI vectors).

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Stripe — payments & webhooks (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Resend — email notifications
RESEND_API_KEY=
EMAIL_FROM=noreply@moroccowithyou.com
EMAIL_TEAM=team@moroccowithyou.com
