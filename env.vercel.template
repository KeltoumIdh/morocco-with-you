# Vercel → Project → Settings → Environment Variables → Production.
# Replace __...__ from your local .env — never commit real keys to git.
# VITE_API_URL = your Render URL + /api (example shape only).

VITE_SUPABASE_URL=__VITE_SUPABASE_URL__
VITE_SUPABASE_ANON_KEY=__VITE_SUPABASE_ANON_KEY__
VITE_API_URL=__https://YOUR-SERVICE.onrender.com/api__

# Optional: Stripe publishable for checkout in the browser
# VITE_STRIPE_PUBLISHABLE_KEY=__VITE_STRIPE_PUBLISHABLE_KEY__

# Optional: separate admin host or same app
# VITE_ADMIN_URL=/admin/dashboard
# VITE_ADMIN_OPEN_NEW_TAB=0

# Do NOT put server secrets here (no service_role, no STRIPE_SECRET, no GEMINI server key).
