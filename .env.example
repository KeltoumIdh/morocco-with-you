# ── Morocco With You — Frontend Environment ────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase (find in: Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# New Express server (port 3001)
VITE_SERVER_URL=http://localhost:3001/api

# Main API base (Express + Supabase backend)
VITE_API_URL=http://localhost:3001/api

# Admin dashboard URL from customer shell (default: /admin/dashboard same app)
# VITE_ADMIN_URL=https://admin.yourdomain.com
# Open admin in new tab (1 = yes — typical when VITE_ADMIN_URL is another origin)
# VITE_ADMIN_OPEN_NEW_TAB=0

# Stripe (optional — publishable key for future embedded Elements)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Itinerary route: stylized Marrakech preview + “Coming soon” (default). Set to 0 for live OpenStreetMap.
# VITE_ITINERARY_ROUTE_MAP_COMING_SOON=0
